# Odysseus Multi-Model Chat Configuration
# Supports: Claude (Anthropic), Ollama (Local), OpenAI, and other providers

# ============================================================
# PRIMARY LLM CONFIGURATION
# ============================================================

# Local Ollama (comment out if not using)
LLM_HOST=localhost
OLLAMA_BASE_URL=http://localhost:11434

# ============================================================
# CLAUDE API CONFIGURATION (Anthropic)
# ============================================================

# Claude API Key - Get from: https://console.anthropic.com/account/keys
# Uncomment and add your key below
# CLAUDE_API_KEY=sk-ant-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Claude API endpoint (already configured, no changes needed)
# Models available: claude-3-5-sonnet, claude-3-opus, claude-3-sonnet, claude-3-haiku

# ============================================================
# OPENAI CONFIGURATION (Optional)
# ============================================================

# OpenAI API Key - Get from: https://platform.openai.com/account/api-keys
# Uncomment and add your key below
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# Search & Web
# ============================================================

SEARXNG_INSTANCE=http://localhost:8080

# ============================================================
# Database
# ============================================================

DATABASE_URL=sqlite:///./data/app.db

# ============================================================
# Auth & Security
# ============================================================

AUTH_ENABLED=true
APP_BIND=127.0.0.1
APP_PORT=7000

# ============================================================
# ChromaDB (vector store for memory)
# ============================================================

CHROMADB_HOST=localhost
CHROMADB_PORT=8100

# ============================================================
# RAG / Embeddings (Optional)
# ============================================================

# Use Ollama for embeddings (no extra cost)
EMBEDDING_URL=http://localhost:11434/v1/embeddings
EMBEDDING_MODEL=all-minilm:l6-v2

# Or use local fastembed
# FASTEMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
