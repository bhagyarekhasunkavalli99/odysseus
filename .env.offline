# Odysseus Offline Environment Configuration
# Use this for offline-only operation with local Ollama models

# ============================================================
# LLM Configuration - LOCAL MODELS ONLY
# ============================================================

# Local Ollama instance (must be running: ollama serve)
LLM_HOST=localhost
OLLAMA_BASE_URL=http://localhost:11434

# Local embedding model (optional, uses fastembed for offline embedding)
FASTEMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ============================================================
# Disable Online Services
# ============================================================

# Disable web search (requires internet)
SEARXNG_INSTANCE=disabled

# Disable email polling (requires internet)
ODYSSEUS_INPROCESS_POLLERS=0

# Disable scheduled tasks that need internet
ODYSSEUS_INPROCESS_TASKS=0

# ============================================================
# Auth & Security
# ============================================================

AUTH_ENABLED=true
APP_BIND=127.0.0.1
APP_PORT=7000

# ============================================================
# Database (local only)
# ============================================================

DATABASE_URL=sqlite:///./data/app.db

# ============================================================
# Offline Data Directory
# ============================================================

ODYSSEUS_DATA_DIR=./data

# ============================================================
# Disable Online APIs
# ============================================================

# Do NOT set these for offline operation:
# OPENAI_API_KEY=
# RESEARCH_LLM_ENDPOINT=
# EMBEDDING_URL=

# ============================================================
# Other Settings
# ============================================================

# Cleanup interval
CLEANUP_INTERVAL_HOURS=24

# No ChromaDB needed for basic offline operation
# CHROMADB_HOST=localhost
# CHROMADB_PORT=8100
